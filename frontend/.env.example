# ─────────────────────────────────────────────────────────────────────────────
# SustainAlign frontend — environment example
# Copy to `.env`. Vite exposes only variables prefixed with VITE_ to the client.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for API requests.
# - In DEVELOPMENT: leave EMPTY so requests go to /api and are proxied by Vite
#   to the backend (see vite.config). Equivalent: VITE_API_BASE_URL=
# - In PRODUCTION: set to the absolute backend origin, e.g. https://api.sustainalign.com
VITE_API_BASE_URL=

# Polling interval (ms) for live impact dashboards that use useImpactPolling.
VITE_IMPACT_POLL_INTERVAL_MS=30000
