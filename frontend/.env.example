# ─────────────────────────────────────────────────────────────────────────────
# SustainAlign frontend — environment example
# Copy to `.env`. Vite exposes only variables prefixed with VITE_ to the client.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for API requests.
# In dev: leave empty so Vite proxies /api/* to the backend.
# In prod: set to the full origin, e.g. https://sustainalign.com/api
# To use API v1: change to /api/v1 (requires backend on v1)
VITE_API_BASE_URL=

# Polling interval (ms) for live impact dashboards that use useImpactPolling.
VITE_IMPACT_POLL_INTERVAL_MS=30000

# Sentry DSN for client-side error tracking. Leave empty to disable.
VITE_SENTRY_DSN=

# Site URL for SEO meta tags and Open Graph.
# In production: set to your deployed frontend URL, e.g. https://sustainalign.com
VITE_SITE_URL=
