# SustainAlign Deploy Configuration
# Copy to .env.deploy and fill in values

DEPLOY_BRANCH=main
DEPLOY_HOST=your-server-ip
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/sustainalign
DEPLOY_SSH_KEY=~/.ssh/id_ed25519

GRAFANA_ADMIN_PASSWORD=changeme

# Feature flags
FEATURE_AI_ENABLED=true
FEATURE_EMAIL_ENABLED=true
