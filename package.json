{
  "name": "sustainalign",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered CSR (Section 135) management platform connecting corporates, NGOs, and platform admins.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "echo \"Run 'npm run dev --workspace backend' and 'npm run dev --workspace frontend' in separate terminals.\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "backend/src/**/*.js": [
      "prettier --write --ignore-unknown"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "prettier --write --ignore-unknown"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.1"
  }
}
