{
  "title": "SustainAlign Logs",
  "uid": "sustainalign-logs",
  "tags": ["sustainalign", "logs"],
  "timezone": "browser",
  "panels": [
    {
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "{container=~\"backend|frontend\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "{container=~\"backend|frontend\"} |= \"error\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Auth Events",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "{container=\"backend\"} |= \"auth event\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
