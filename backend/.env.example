# ─────────────────────────────────────────────────────────────────────────────
# SustainAlign backend — environment example
# Copy to `.env` and edit. All variables are validated by Zod at boot
# (see src/config/env.js). Unknown / invalid values will stop the server.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development            # development | production | test
PORT=3001

# CORS — set the frontend origin. APP_URL is used for email links (reset, invites).
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────────
# SQLite path (relative to backend/). WAL mode is enabled automatically.
# For production: back this file up regularly and run a single-instance deploy.
DATABASE_PATH=./data/sustainalign.db

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# REQUIRED in production: each must be ≥ 32 chars and the two must differ,
# otherwise the server refuses to boot (see validateProduction in env.js).
# Generate strong values with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=dev-secret-change-me-in-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-prod-32
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ── File storage ────────────────────────────────────────────────────────────
# Only "local" is implemented today; an S3-compatible provider is planned.
STORAGE_PROVIDER=local
UPLOAD_ROOT=./uploads
MAX_FILE_SIZE_MB=10

# ── Email (transactional) ───────────────────────────────────────────────────
# Optional in development (the app degrades gracefully and logs instead).
# Required in production for MFA codes, password reset, and invitations.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SustainAlign <no-reply@sustainalign.com>"

# ── AI / RAG (Ollama) ───────────────────────────────────────────────────────
# Optional. Copilot / RAG features require a running Ollama instance.
# Set AI_ENABLED=false to disable AI features entirely.
AI_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Compliance scheduler ────────────────────────────────────────────────────
# How often (minutes) the in-process compliance scheduler re-evaluates rules.
COMPLIANCE_SYNC_INTERVAL_MINUTES=60

# ── Reverse proxy ──────────────────────────────────────────────────────────
# Number of proxy hops to trust for req.ip (used by rate limiter).
# Set to 0 if deploying without a reverse proxy.
TRUST_PROXY=1
