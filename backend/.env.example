PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
DATABASE_PATH=./data/sustainalign.db
JWT_SECRET=dev-secret-change-me-in-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-prod-32
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
APP_URL=http://localhost:5173
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@sustainalign.com

# Step 0 — file storage (local disk)
STORAGE_PROVIDER=local
UPLOAD_ROOT=./uploads
MAX_FILE_SIZE_MB=10

# Step 7 — Ollama AI (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
AI_ENABLED=true
